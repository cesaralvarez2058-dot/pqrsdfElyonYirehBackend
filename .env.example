# Copia este archivo como .env y rellena los valores reales
# NO subas el .env a GitHub

# Base de datos PostgreSQL (Supabase u otro proveedor)
DB_URL=jdbc:postgresql://HOST:PORT/DATABASE?sslmode=disable
DB_USERNAME=tu_usuario_db
DB_PASSWORD=tu_contraseña_db

# Correo electrónico para envío de notificaciones (Gmail)
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password_gmail

# Email del administrador del sistema
ADMIN_EMAIL=admin@tu_dominio.com
